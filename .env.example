## Bye Netflix — Environment Configuration
## Copy this file to .env and fill in your values.
## Or run setup.sh to generate .env interactively.

# ─── System ──────────────────────────────────────────────────────────────────
# Your timezone. Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Paris

# User and group ID to run containers as.
# Find yours with: id -u && id -g
PUID=1000
PGID=1000

# ─── Storage ─────────────────────────────────────────────────────────────────
# Two configurations are supported:
#
# Single drive:
#   MEDIA_DIR=/srv/media          ← movies and TV live here
#   DOWNLOADS_DIR=/srv/downloads  ← downloads land here (same drive)
#   Radarr/Sonarr hardlink files from /downloads → /media on import (instant, no copy)
#
# SSD + HDD:
#   MEDIA_DIR=/mnt/hdd/media      ← movies and TV live here (HDD)
#   DOWNLOADS_DIR=/mnt/ssd        ← downloads land here (SSD, fast)
#   Radarr/Sonarr copy files from SSD → HDD on import (cross-filesystem, expected)

# Where your media library lives (HDD or single drive).
# Mounted at /media inside containers. Set root folders to /media/movies and /media/tv.
MEDIA_DIR=/srv/media

# Where downloads land before Radarr/Sonarr import them.
# Mounted at /downloads inside containers.
# Point your download client's completed folder here.
DOWNLOADS_DIR=/srv/downloads

# ─── Plex ────────────────────────────────────────────────────────────────────
# Get a one-time claim token at https://www.plex.tv/claim (expires in 4 min).
# Only needed on first run to link the server to your account.
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# ─── Torrent client (docker-compose.torrent.yml) ─────────────────────────────
DELUGE_PASSWORD=changeme

# ─── VPN (docker-compose.vpn.yml) ────────────────────────────────────────────
# Port forwarded through your VPN provider (for seeding).
# Find this on your VPN provider's dashboard/portal.
VPN_FORWARDED_PORT=12345

# Subnets that Gluetun should allow through its firewall (so containers can
# still reach each other and your LAN). Adjust to match your Docker and LAN subnets.
VPN_FIREWALL_SUBNETS=172.18.0.0/16,172.19.0.0/16,192.168.1.0/24

# ─── Trakt (docker-compose.trakt.yml) ────────────────────────────────────────
# Create an app at https://trakt.tv/oauth/applications/new
# Redirect URI must be: urn:ietf:wg:oauth:2.0:oob
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# Radarr and Sonarr API keys (Settings → General → API Key in each app).
# These are blank until after first run — fill in after the stack is running.
RADARR_API_KEY=
SONARR_API_KEY=

# Root folders inside the containers where media is stored.
RADARR_ROOT_FOLDER=/media/movies
SONARR_ROOT_FOLDER=/media/tv

# Quality profile name as it appears in Radarr/Sonarr.
RADARR_QUALITY_PROFILE=Any
SONARR_QUALITY_PROFILE=Any

# ─── macvlan / Plex LAN IP (docker-compose.macvlan.yml) ──────────────────────
# An unused IP on your local network to assign to Plex.
PLEX_LAN_IP=192.168.1.100

# Your host machine's network interface. Find it with: ip link show
PLEX_LAN_INTERFACE=eth0

# Your LAN subnet.
PLEX_LAN_SUBNET=192.168.1.0/24

# Your router's IP (default gateway).
PLEX_LAN_GATEWAY=192.168.1.1
